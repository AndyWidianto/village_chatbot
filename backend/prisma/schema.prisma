// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum UserRole {
  admin
  super_admin
  review
}

model User {
  id           String   @id @default(uuid())
  name         String?
  username     String   @unique
  password     String
  email        String   @unique
  refreshToken String?
  role         UserRole

  thumbnail    String?
  profileUrl   String?

  notifications Notification[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([username, email])
  @@map("users")
}


enum StatusDevice {
  CONNECTING
  CONNECTED
  DISCONNECTED
}
model Device {
  id           String  @id @default(uuid())
  name         String
  number       String?
  instanceName String  @unique
  status       StatusDevice @default(CONNECTING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([number, instanceName])
  @@map("devices")
}

model Knowledge {
  id        String                       @id @default(uuid())
  name      String                       @default("")
  content   String                       @db.Text
  embedding Unsupported("vector(1024)")?
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  @@map("knowledges")
}

model Message {
  id         String  @id @default(uuid())
  // Info WhatsApp (External ID dari Evolution API)
  whatsappId String? @map("whatsapp_id")
  fromMe     Boolean @default(false) @map("from_me")
  remoteJid  String  @map("remote_jid")
  pushName   String? @map("push_name")

  // Konten Pesan
  content String @db.Text
  type    String @default("text") // text, image, document, dll.

  // Metadata & Audit
  status    String   @default("sent") // sent, delivered, read, failed
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([remoteJid]) // Indexing penting untuk tarik history chat
  @@map("messages")
}

model Autoreply {
  id String @id @default(uuid())

  // Identitas & Status
  name     String // Nama aturan (misal: "CS Layanan KTP")
  isActive Boolean @default(true) @map("is_active")

  // Logic Trigger
  type           String  @default("keyword") // "keyword", "ai_rag", or "fallback"
  triggerKeyword String? @map("trigger_keyword") // Hanya isi jika type="keyword"

  // Response Logic
  replyContent String? @map("reply_content") @db.Text // Jawaban statis (jika bukan AI)
  aiPrompt     String? @map("ai_prompt") @db.Text // System Prompt khusus buat AI ini

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("auto_replies")
}

model Notification {
  id String @id @default(uuid())
  title     String
  content   String   @db.Text
  type      String   // 'info', 'warning', 'error', 'success'
  isRead    Boolean  @default(false)
  userId    String?   
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model Citizen {
  id            String         @id @default(uuid())
  nik           String?        @unique // Optional, can be filled during chatbot verification
  fullName      String?        
  platformId    String         @unique // Unique ID from platform (e.g., WhatsApp number "62812xxx" or Telegram ID)
  platform      ChatPlatform
  subDistrict   String?        // Neighborhood/ Hamlet / RT / RW info for mapping
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  complaints    Complaint[]

  @@index([platformId]) // Index for fast lookup when chatbot receives a message
}

model Complaint {
  id              String          @id @default(uuid())
  ticketNumber    String          @unique // Auto-generated format, e.g., COMP-2026-0001
  title           String          // Short summary of the complaint
  description     String          @db.Text
  category        ComplaintCategory
  status          ComplaintStatus @default(PENDING)
  attachmentUrl   String?         // Photo/file attachment link from chatbot
  publicId        String?
  officerNotes    String?         @db.Text // Response or notes from village officials
  
  citizenId       String
  citizen         Citizen         @relation(fields: [citizenId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([ticketNumber])
  @@index([status])
}


enum ChatPlatform {
  WHATSAPP
  TELEGRAM
  WEB_CHAT
}

enum ComplaintCategory {
  INFRASTRUCTURE  // Broken roads, broken street lights, bridges
  ADMINISTRATION  // ID cards (KTP/KK) processing, cover letters
  SECURITY        // Theft, neighborhood watch, conflicts
  SOCIAL_ASSISTANCE // Social aid, BLT, house renovations
  HEALTH          // Posyandu services, disease outbreaks
  OTHERS
}

enum ComplaintStatus {
  PENDING     // Newly submitted via chatbot
  IN_PROGRESS // Being handled by village officials
  RESOLVED    // Successfully resolved
  REJECTED    // Invalid or spam report
}

